{
  "name": "@xpntl/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "migrate:up": "node-pg-migrate up -m ./migrations -j sql",
    "migrate:down": "node-pg-migrate down -m ./migrations -j sql",
    "migrate:create": "node-pg-migrate create -m ./migrations -j sql --name",
    "seed:dev": "tsx src/seed/dev.ts",
    "seed:test": "tsx src/seed/test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "node-pg-migrate": "^7.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
