# Copy to .env for local development. Never commit .env.

# --- Database -------------------------------------------------------------
DATABASE_URL=postgres://xpntl:xpntl@localhost:5432/xpntl

# --- Auth -----------------------------------------------------------------
JWT_SECRET=dev-secret-change-me-in-production
SESSION_SECRET=dev-session-secret-change-me-too

# --- Object storage (Azurite in dev, Azure Blob in prod) ------------------
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# --- Email (Mailpit in dev) -----------------------------------------------
MAILER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=xpntl-dev@localhost

# --- Public URLs ----------------------------------------------------------
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WEB_URL=http://localhost:5173
MARKETING_SITE_URL=http://localhost:5174

# --- Stripe (billing) -----------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=

# --- OAuth providers (all optional — SSO buttons hidden when unset) -------
# Azure Container Apps maps these from Key Vault secrets (kebab-case)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
# Apple: APPLE_CLIENT_ID is the Service ID (e.g. app.xpntl.signin), used as the
# id_token audience. Preferred path — the API mints the ES256 client_secret JWT
# from your .p8 (no manual 6-month rotation): set TEAM_ID + KEY_ID + PRIVATE_KEY.
# PRIVATE_KEY is the full .p8 PEM; escaped \n in single-line env values is fine.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# Legacy fallback only (a hand-minted JWT, ≤6-month expiry) if the .p8 vars above
# are not set:
APPLE_CLIENT_SECRET=

# --- Social / X (Twitter) -------------------------------------------------
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
ANTHROPIC_API_KEY=

# --- Background jobs ------------------------------------------------------
# The API runs recurrence/webhook/social ticks embedded by default. Set to
# 'true' only once a dedicated worker (apps/worker) is deployed, to avoid
# double-processing. (Webhook delivery is concurrency-safe regardless.)
DISABLE_EMBEDDED_TICKS=

# --- Ports ----------------------------------------------------------------
PORT_API=4000
PORT_SYNC=4001
PORT_MCP=4002
PORT_WEB=5173
