{
  "name": "@xpntl/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/server.js",
    "./mount": "./dist/mount.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/http.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xpntl/db": "workspace:*",
    "@xpntl/domain": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
